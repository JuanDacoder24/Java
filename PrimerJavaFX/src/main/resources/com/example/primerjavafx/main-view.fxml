<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.primerjavafx.MainController">
   <children>
      <VBox alignment="CENTER" minHeight="640.0" minWidth="640.0" prefHeight="640.0" prefWidth="640.0" spacing="20.0">
          <padding>
              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
          </padding>
      
          <Label fx:id="welcomeText" />
          <Button fx:id="btnHola" onAction="#onHelloButtonClick" prefHeight="44.0" prefWidth="147.0" style="-fx-background-color: black;" text="Hola" textFill="WHITE">
            <font>
               <Font name="Arial Black" size="12.0" />
            </font>
            <VBox.margin>
               <Insets top="300.0" />
            </VBox.margin>
         </Button>
      </VBox>
   </children>
</AnchorPane>
